-- PMS PostgreSQL Database Schema

-- 1. ENUMS (For Roles and Transaction Purposes)
DO $$ BEGIN
    CREATE TYPE user_role AS ENUM ('employee', 'admin', 'super_admin');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

DO $$ BEGIN
    CREATE TYPE transaction_purpose AS ENUM ('Start', 'Buy Back', 'Renew', 'Sold Item', 'Pawn', 'Cash Transfer', 'Fund Transfer');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

-- 2. BRANCHES TABLE (Supports Multi-Branch)
CREATE TABLE IF NOT EXISTS branches (
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    location VARCHAR(255),
    -- Balance caching optionally handled here, but proper historical balance is in daily_balances
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 3. USERS TABLE (Supports 3 Roles)
CREATE TABLE IF NOT EXISTS users (
    id SERIAL PRIMARY KEY,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    role user_role NOT NULL DEFAULT 'employee',
    branch_id INT REFERENCES branches(id) ON DELETE SET NULL, -- Super admin = null, regular = specific branch
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 4. DAILY BALANCES TABLE (For the 12:00 AM Carry-Over Logic)
CREATE TABLE IF NOT EXISTS daily_balances (
    id SERIAL PRIMARY KEY,
    branch_id INT NOT NULL REFERENCES branches(id) ON DELETE CASCADE,
    record_date DATE NOT NULL,
    starting_balance NUMERIC(12, 2) NOT NULL DEFAULT 0.00,
    ending_balance NUMERIC(12, 2) NOT NULL DEFAULT 0.00,
    UNIQUE(branch_id, record_date) 
);

-- 5. TRANSACTIONS TABLE (The Core Transactions Logic)
CREATE TABLE IF NOT EXISTS transactions (
    id SERIAL PRIMARY KEY,
    transaction_no VARCHAR(50) UNIQUE NOT NULL, -- e.g., 'SJS007610'
    branch_id INT NOT NULL REFERENCES branches(id) ON DELETE CASCADE,
    user_id INT NOT NULL REFERENCES users(id), -- Who created the transaction
    
    purpose transaction_purpose NOT NULL,
    transaction_date DATE NOT NULL DEFAULT CURRENT_DATE,
    transaction_time TIME NOT NULL DEFAULT CURRENT_TIME,
    
    -- Cash In Logic (Now editable with details)
    cash_in NUMERIC(12, 2) DEFAULT 0.00,
    cash_in_details VARCHAR(255), -- "Cash from management", "Downpayment", etc.
    
    cash_out NUMERIC(12, 2) DEFAULT 0.00,
    return_val NUMERIC(12, 2) DEFAULT 0.00,
    
    -- Item Properties
    unit VARCHAR(255),
    unit_code VARCHAR(100),
    pawn NUMERIC(12, 2) DEFAULT 0.00,
    storage NUMERIC(12, 2) DEFAULT 0.00,
    profile_photo TEXT,
    id_photo TEXT,
    
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- INDEXES for fast querying by branch and dashboard calculations
CREATE INDEX IF NOT EXISTS idx_transactions_branch_date ON transactions(branch_id, transaction_date);
CREATE INDEX IF NOT EXISTS idx_daily_balances_branch_date ON daily_balances(branch_id, record_date);

-- ═══════════════════════════════════════════════════════════════
-- 6. INVENTORY: PAWNED ITEMS
-- ═══════════════════════════════════════════════════════════════
DO $$ BEGIN
    CREATE TYPE pawned_status AS ENUM ('Active', 'Redeemed', 'Expired');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

CREATE TABLE IF NOT EXISTS pawned_items (
    id SERIAL PRIMARY KEY,
    item_id VARCHAR(20) UNIQUE NOT NULL,  -- Auto-sequential: 001, 002, 003...
    item_name VARCHAR(255) NOT NULL,
    category VARCHAR(100),
    branch VARCHAR(100) NOT NULL,
    branch_id INT REFERENCES branches(id) ON DELETE CASCADE,
    pawn_date DATE NOT NULL DEFAULT CURRENT_DATE,
    status pawned_status NOT NULL DEFAULT 'Active',
    remarks TEXT,                          -- Admin editable notes (defects, investigations, etc.)
    qr_code TEXT,                          -- QR code data for vault tally
    profile_photo TEXT,                    -- Customer photo
    id_photo TEXT,                         -- ID photo
    condition_report TEXT,                 -- Condition when received
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- Auto-generate sequential item_id (001, 002, 003...)
CREATE OR REPLACE FUNCTION generate_pawned_item_id()
RETURNS TRIGGER AS $$
BEGIN
    NEW.item_id := LPAD((SELECT COALESCE(MAX(id), 0) + 1 FROM pawned_items)::TEXT, 3, '0');
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_pawned_item_id
BEFORE INSERT ON pawned_items
FOR EACH ROW EXECUTE FUNCTION generate_pawned_item_id();

-- 7. RENEWAL TRACKING (per pawned item)
CREATE TABLE IF NOT EXISTS item_renewals (
    id SERIAL PRIMARY KEY,
    pawned_item_id INT NOT NULL REFERENCES pawned_items(id) ON DELETE CASCADE,
    renewal_date DATE NOT NULL DEFAULT CURRENT_DATE,
    amount_paid NUMERIC(12, 2) NOT NULL DEFAULT 0.00,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- ═══════════════════════════════════════════════════════════════
-- 8. INVENTORY: ITEMS FOR SALE (auto-transferred from Expired pawned items)
-- ═══════════════════════════════════════════════════════════════
DO $$ BEGIN
    CREATE TYPE sale_status AS ENUM ('Available', 'Sold');
EXCEPTION
    WHEN duplicate_object THEN null;
END $$;

CREATE TABLE IF NOT EXISTS sale_items (
    id SERIAL PRIMARY KEY,
    item_id VARCHAR(20) UNIQUE NOT NULL,
    item_name VARCHAR(255) NOT NULL,
    category VARCHAR(100),
    branch VARCHAR(100) NOT NULL,
    branch_id INT REFERENCES branches(id) ON DELETE CASCADE,
    available_date DATE NOT NULL DEFAULT CURRENT_DATE,
    price NUMERIC(12, 2) NOT NULL DEFAULT 0.00,
    status sale_status NOT NULL DEFAULT 'Available',
    original_pawn_id INT REFERENCES pawned_items(id), -- Link back to the original pawned item
    sold_date DATE,                                    -- Date when item was sold
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- Auto-generate sequential item_id for sale items
CREATE OR REPLACE FUNCTION generate_sale_item_id()
RETURNS TRIGGER AS $$
BEGIN
    NEW.item_id := 'S-' || LPAD((SELECT COALESCE(MAX(id), 0) + 1 FROM sale_items)::TEXT, 3, '0');
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_sale_item_id
BEFORE INSERT ON sale_items
FOR EACH ROW EXECUTE FUNCTION generate_sale_item_id();

-- INDEXES for inventory
CREATE INDEX IF NOT EXISTS idx_pawned_items_branch ON pawned_items(branch_id, status);
CREATE INDEX IF NOT EXISTS idx_sale_items_branch ON sale_items(branch_id, status);
CREATE INDEX IF NOT EXISTS idx_renewals_item ON item_renewals(pawned_item_id);

